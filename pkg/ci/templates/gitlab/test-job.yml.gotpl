{{ define "test-job.yml.gotpl" }}
test-{{ .Image.Name }}:
  extends: .test
  stage: test-{{ .Image.Name }}
  variables:
    IMAGE_NAME: {{ .Image.Name }}
  needs:
    - generate
{{- range .Image.Platforms }}
    - build-{{ $.Image.Name }}-{{ . }}
{{- end }}
  artifacts:
    when: always
    paths:
      - {{ .Ctx.Dist }}/**/*-cst-report.xml
    reports:
      junit: {{ .Ctx.Dist }}/**/*-cst-report.xml
{{- end }}
