{{ define "test-job.yml.gotpl" }}
test-{{ .Image.Name }}:
  extends: .test
  variables:
    IMAGE_NAME: {{ .Image.Name }}
  needs:
    - generate
    - manifest-{{ .Image.Name }}
  artifacts:
    when: always
    paths:
      - {{ .Ctx.Dist }}/**/*-cst-report.xml
    reports:
      junit: {{ .Ctx.Dist }}/**/*-cst-report.xml
{{- end }}
