{{ define "test-job.yml.gotpl" }}
  test-{{ .Image.Name }}:
    runs-on: ubuntu-latest
    container: {{ .Ctx.ImageName }}:{{ .Ctx.Version }}
    services:
      dind:
        image: docker:dind
        options: --privileged
        env:
          DOCKER_TLS_CERTDIR: ""
    env:
      DOCKER_HOST: tcp://dind:2375
    needs:
      - manifest-{{ .Image.Name }}
    steps:
      - uses: actions/checkout@v4
        with:
          lfs: true
      - uses: actions/download-artifact@v4
        with:
          name: generated
          path: {{ .Ctx.Dist }}/
{{- if $.Ctx.Artifacts }}
      - uses: actions/download-artifact@v4
        with:
          name: {{ .Image.Name }}-manifest
          path: {{ .Ctx.Dist }}/
{{- end }}
      - run: echo "${{ "{{" }} secrets.GITHUB_TOKEN {{ "}}" }}" | {{ .Ctx.ChCmd }} login -u "${{ "{{" }} github.actor {{ "}}" }}" --password-stdin ghcr.io
      - run: {{ .Ctx.ChCmd }} wait --docker-socket
      - run: {{ .Ctx.ChCmd }} test {{ .Image.Name }} --build-id "$SNAPSHOT_ID"{{ if not $.Ctx.Artifacts }} --pull{{ end }}
{{- end }}