{{ define "test-job.yml.gotpl" }}
  test-{{ .Image.Name }}:
    runs-on: ubuntu-latest
    needs:
      - manifest-{{ .Image.Name }}
    steps:
      - name: Checkout code
        uses: actions/checkout@v6
        with:
          lfs: true
      - name: Download generated files
        uses: actions/download-artifact@v7
        with:
          name: generated
          path: {{ .Ctx.Dist }}/
{{- if $.Ctx.Artifacts }}
      - name: Download manifest artifacts
        uses: actions/download-artifact@v7
        with:
          name: {{ .Image.Name }}-manifest
          path: {{ .Ctx.Dist }}/
{{- end }}
      - name: Prepare temp directory
        run: mkdir -p "$RUNNER_TEMP/ch"
      - name: Setup QEMU
        run: docker run --rm --privileged multiarch/qemu-user-static --reset -p yes
      - name: Create Docker network
        run: docker network create ch-net
      - name: Start Docker-in-Docker
        run: docker run -d --name dind --privileged --network ch-net -e DOCKER_TLS_CERTDIR="" docker:dind
      - name: Login to GHCR
        run: echo "${{ "{{" }} secrets.GITHUB_TOKEN {{ "}}" }}" | docker run --rm --entrypoint="" -u "$(id -u):$(id -g)" -e CI=1 -i -e HOME="$RUNNER_TEMP/ch" -v "$RUNNER_TEMP/ch:$RUNNER_TEMP/ch" -v "$GITHUB_WORKSPACE:$GITHUB_WORKSPACE" -w "$GITHUB_WORKSPACE" --network ch-net -e DOCKER_HOST=tcp://dind:2375 $CH_IMAGE {{ .Ctx.ChCmd }} login -u "${{ "{{" }} github.actor {{ "}}" }}" --password-stdin ghcr.io
      - name: Wait for Docker socket
        run: docker run --rm --entrypoint="" -u "$(id -u):$(id -g)" -e CI=1 -e HOME="$RUNNER_TEMP/ch" -v "$RUNNER_TEMP/ch:$RUNNER_TEMP/ch" -v "$GITHUB_WORKSPACE:$GITHUB_WORKSPACE" -w "$GITHUB_WORKSPACE" --network ch-net -e DOCKER_HOST=tcp://dind:2375 $CH_IMAGE {{ .Ctx.ChCmd }} wait --docker-socket
      - name: Run container tests
        run: docker run --rm --entrypoint="" -u "$(id -u):$(id -g)" -e CI=1 -e HOME="$RUNNER_TEMP/ch" -v "$RUNNER_TEMP/ch:$RUNNER_TEMP/ch" -v "$GITHUB_WORKSPACE:$GITHUB_WORKSPACE" -w "$GITHUB_WORKSPACE" --network ch-net -e DOCKER_HOST=tcp://dind:2375 $CH_IMAGE {{ .Ctx.ChCmd }} test {{ .Image.Name }} --build-id "$SNAPSHOT_ID"
      - name: Publish Test Report
        id: test-report
        uses: mikepenz/action-junit-report@v6
        if: success() || failure()
        with:
          check_name: "Container Structure Tests - {{ .Image.Name }}"
          report_paths: '{{ .Ctx.Dist }}/**/*-cst-report.xml'
          require_tests: 'false'
          detailed_summary: 'true'
          comment: 'true'
          updateComment: 'true'
          include_passed: 'true'
{{- end }}
