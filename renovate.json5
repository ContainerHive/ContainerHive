{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>timo-reymann/renovate-config"
  ],
  "regexManagers": [
    {
      "description": "Update GitHub Actions versions in internal/actions/versions.go via renovate comments",
      "fileMatch": ["internal/actions/versions\\.go$"],
      "matchStrings": [
        "=\\s*\"(?<currentValue>[^\"]+)\"\\s+//\\s+renovate:\\s+datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)"
      ]
    }
  ]
}